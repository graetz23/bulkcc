<codeline><highlight class="normal"><ref refid="classBULKCC_1_1Controller_1ac20c894a3ecf56cd86c37b6828debf26" kindref="member">controller</ref>.erase(<ref refid="classBULKCC_1_1Controller_1ac20c894a3ecf56cd86c37b6828debf26" kindref="member">stack</ref>);<sp/><sp/></highlight><highlight class="comment">//<sp/>Then<sp/>delete<sp/>stack<sp/>nodes</highlight></codeline>
</programlisting> </para>
        </detaileddescription>
